  	  "audio": "",
	  "waitAudio": false,
	  "dialogue": [ 
	    {
		"option": ["1"],
		"messages": [{ "text": "O camburão está pronto?", "response": "Sim. Quem são os supeitos?" }, { "text": "Primeiro, o Sr. Meirelles. Ele é suspeito de matar acidentalmente o pai de Lúcia.", "response": "Ouch." },{ "text": "Mas a sua esposa é inocente.", "response": "Certo. Menos uma para o camburão." }, { "text": "E Carolina também não teve nada a ver com a história.", "response": "Ótimo." }, { "text": "Mas o General é culpado.", "response": "Sério? Quem poderia imaginar..."}, { "text": "Corrupção. Adquiriu o terreno onde seria construída a refinaria\nquando soube sobre os planos.", "response": "Alguém deve ter ajudado ele nessa jogada..." },{ "text": "O Dr. Marcos.", "response": "Caramba!" },{ "text": "Quando foi contratado para realizar os projetos, chamou o General\npara participar do esquema.", "response": "Agora vão poder compartilhar de um esquema na cadeia." },{ "text": "Genésio, o caseiro, é inocente.", "response": "O mordomo nem sempre é o culpado..."},{ "text": "Só na ficção barata, Iago.", "response": "É o que você diz. Quem mais?"},{ "text": "Lúcia quis sua vingança.", "response": "A recatada?"},{ "text": "Nunca duvide do poder de uma mente ardilosa.", "response": "Mais uma para o camburão."},{ "text": "Sandra não fez nada.", "response": "Ainda bem, ou não caberia todo mundo."},{ "text": "Mas Mary se aproveitou da confusão para tentar ficar com o diamante.", "response": "Uma ladra de ocasião."}],
		"jump":"irFinal"
		}],
	  "jump": "",
