  	  "audio": "",
	  "waitAudio": false,
      "dialogue": [ 
	    {
		"option": ["1"],
		"messages": [
          { "text": "Boa noite. Eu sou o Inspetor Zanko.", "response": "Ah, estávamos esperando o senhor. \nO Dr. Meirelles está no escritório." },
		  { "text": "Muito obrigado.", "response": "Não há de quê." }],
		"jump": "ativaCenaHall01"
		}],
	  "jump": "",
      "defaultDialogue": [
        { "text": "Onde está o Dr. Meirelles, mesmo?", "response": "No escritório, Inspetor." }],
      "conditionalDialogue": [{
          "id": "cd.CAR.D01",
		  "requiresClues": ["PistaLAB.CAR"],
          "messages": [
            { "text": "Sabe o que encontrei no chá gelado que serviu para o Dr. Marcos?", "response": "Vodca?" },
			{ "text": "Você serve vodca no chá?", "response": "Errei alguns drinques hoje e..." },
            { "text": "Não era vodca. Era o 'Olho de Odin'.", "response": "O diamante?"},
            { "text": "Como se fosse um cubo de gelo.", "response": "Um gelo bem caro."},
            { "text": "Nem me diga... Como o diamante foi parar lá?", "response": "Não tenho ideia, Inspetor. Apenas fiz o chá e peguei o gelo na geladeira."},
            { "text": "Viu alguém entrando na cozinha?", "response": "🔍 Todo mundo vai na cozinha o tempo todo."},
            { "text": "Então, poderia ter sido qualquer um?", "response": "Exato, Inspetor."}],
           "jump": "liberaPistaCozinha"
		   },
		   {
          "id": "cd.CAR.D02",
		  "requiresClues": ["PistaESC.ACI"],
          "messages": [
            { "text": "Você trabalha para o Dr. Meirelles há um bom tempo.?", "response": "Desde os quinze anos, Inspetor." },
			{ "text": "Então, já viu de tudo nessa casa. Já conhecia Lúcia?", "response": "Ela frequenta a casa há muitos anos." },
            { "text": "O pai dela morreu em um acidente, não?", "response": "Já ouvi falar disso, mas não sei de nada, não senhor."},
            { "text": "E quem sabe?", "response": "O Dr. Meirelles. Sei que ele mantém 🔍 documentos sobre isso na sua escrivaninha no escritório."}],
           "jump": "liberaPistaEscrivaninha"
		   }
		],
