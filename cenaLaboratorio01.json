{
      "id": "Marcos",
      "type": "Character",
      "name": "Marcos",
      "img": "assets/marcos.png",
	  "icon": "assets/marcosPH.png",
      "width": 94,
      "height": 272,
      "x": 150,
      "y": 220,
      "color": "rgb(199, 144, 55)",
  	  "audio": "",
      "dialogue": [ 
	    {
		"option": "1",
		"messages": [
          { "text": "Bom dia. Eu sou o Inspetor Zanko.", "response": "Bom dia, Inspetor. Eu sou o Dr. Marcos Santos. \nSou engenheiro da refinaria Ipiranga." },
		  { "text": "O que está fazendo aqui no Laboratório do Dr. Meirelles?", "response": "Vim buscar os planos da nova refinaria que \nestamos projetando." },
		  { "text": "E onde estão eles?", "response": "No cofre, mas o Dr. Meirelles simplesmente se esqueceu da combinação. Ele disse que havia anotado os códigos, mas não encontrei nada." }],
		"jump": "ativaLaboratorio"
		}],
	  "jump": "",
  	   "defaultDialogue": [
        { "text": "Onde estão os planos da nova refinaria?", "response": "No cofre, Inspetor." }],
      "conditionalDialogue": [{
          "id": "cd.Laboratorio.01",
		  "requiresClues": ["PistaLAB.PLA1"],
          "messages": [
            { "text": "Esses são os planos da refinaria?", "response": "Acho que sim. Mas parece que há algo errado..." },
			{ "text": "O quê?","response": "🔍 Eles estão incompletos. As especificações da torre de destilação atmosférica não estão aqui." },
			{ "text": "Quem era o responsável por esses planos?","response": "🔍 O Dr. Meirelles." },
			{ "text": "Onde você esteve durante a tarde?","response": "Passei boa parte da tarde aqui no laboratório, trabalhando." },
			{ "text": "Viu alguém durante esse período?","response": "Somente a Carolina. Eu queria tomar chá gelado as 16:00, \nmas não sei o que houve..." },
			{ "text": "Como assim?","response": "Ela encheu o copo com gelo, mas o chá continuava quente. \nDeixei para lá." },
			{ "text": "Onde está o chá?","response": "Deixei nos fundos do laboratório, perto dos livros." }
			],
			"jump": "liberaPistaPlanos"
        },
		{
          "id": "cd.Laboratorio.02",
		  "requiresClues": ["PistaLAB.OLHO"],
          "messages": [
            { "text": "Você sabe o que eu encontrei na sua xícara de chá?", "response": "Açúcar em excesso?" },
			{ "text": "O 'Olho de Odin'.","response": "Impossível!\nVocê precisa acreditar em mim, Inspetor.\nNão tenho nada a ver com esse roubo." },
			{ "text": "Seria o lugar mais estúpido que já vi para esconder um diamante, mesmo...","response": "Obrigado.\nAcho." },
			{ "text": "Quem serviu o chá?","response": "🔍 Carolina." }
			],
			"jump": "liberaPistaCarolinaOlho"
        },
		{
          "id": "cd.Laboratorio.02",
		  "requiresClues": ["PistaLAB.GRG"],
          "messages": [
            { "text": "Sobre essa nova refinaria que vocês estão projetando...", "response": "Desculpe, Inspetor, mas o contrato está sobre segredo." },
			{ "text": "Pelas fotografias, ela vai ser construída em Rio Grande. \nPor que alguém gostaria de sumir com os planos?","response": "🔍 Espionagem industrial? Sabotagem? Irritar os militares?\nPode escolher." },
			{ "text": "Quem tirou as fotografias?","response": "🔍 Eu não sei, mas a Sandra esteve aqui revelando algumas fotos." }
			],
			"jump": "liberaPistaSuspeitos"
        }],
	  "visible": "visible",
	  "active": true,
