	{
      "id": "Lucia",
      "type": "Character",
      "name": "Lúcia",
      "img": "assets/lucia.png",
	  "icon": "assets/luciaPH.png",
      "width": 68,
      "height": 266,
      "x": 255,
      "y": 225,
      "color": "rgb(78, 221, 132)",
  	  "audio": "",
	  "waitAudio": false,
      "dialogue": [ 
	    {
		"option": ["1"],
		"messages": [
          { "text": "Boa noite, senhorita. Eu sou o Inspetor Zanko.", "response": "Olá, Inspetor. O que posso fazer por você?" },
		  { "text": "Estou investigando o desaparecimento do 'Olho de Odin'.", "response": "O diamante do Dr. Meirelles? \nBem, não posso lhe ajudar nisso. Tenho procurado o meu chapéu." },{ "text": "Como?", "response": "O meu chapéu, Inspetor. Estive atrás dele a tarde inteira." },{ "text": "Alguma ideia de onde ele pode estar?", "response": "Se soubesse, não estaria procurando." }],
		"jump": "ativarQuartoAzul"
		}],
	  "acceptedItems": ["objChapeuMulher"],
	  "jumpAfterAccepted": "luciaComChapeu",
	  "messageAccepted": 20,
	  "defaultDialogue": [
        { "text": "Sobre o diamante...", "response": "Não posso lhe responder agora, Inspetor. \nPreciso do meu chapéu." }],	 
      "conditionalDialogue": [{
          "id": "cd.QuartoAzul.01",
		  "requireStates": ["luciaComChapeu"],
          "messages": [
            { "text": "Então, o que sabe sobre o diamante?", "response": "Só sei que o Dr. Meirelles adora exibi-lo por aí." },
			{ "text": "Ele estava no seu escritório.","response": "E eu estava procurando o meu chapéu. Uma mulher que se preze não anda por aí sem o seu chapéu." },
            { "text": "Viu alguém durante a tarde?", "response": "Carolina andando de um lado para o outro, levando bebidas." },
            { "text": "Falou com ela?", "response": "Não me dirijo a empregadas se não tiver nada para falar com elas, Inspetor. Fui muito bem educada." },
            { "text": "Um mulher bela, recatada e do lar...", "response": "Uma descrição apropriada." },
            { "text": "Por que está aqui?", "response": "🔍 Sou amiga de longa data do Dr. Meirelles. Ele pagou os meus estudos após o meu pai morrer." },
            { "text": "Eu sinto muito.", "response": "Eu também, Inspetor." }	
          ],
		  "jump": "conversa01Lucia"
        },
		{
          "id": "cd.QuartoAzul.02",
		  "requiresClues": ["PistaESC.MOR"],
          "messages": [
            { "text": "Eu encontrei alguns documentos intrigantes...", "response": "Que tipo de documentos?" },{ "text": "A senhorita você sabia que o seu pai morreu em um acidente nas Indústrias Meirelles?", "response": "Sim. Sei disso há um bom tempo." },
			{ "text": "E, mesmo assim, você continua frequentando essa casa?","response": "Como o senhor disse, Inspetor, foi um acidente." },
            { "text": "E não guarda mágoas? O Dr. Meirelles não foi responsabilizado...", "response": "🔍 O Dr. Meirelles foi muito bom para nós." }	
          ],
		  "jump": "liberaPistaAcidenteMeirelles"
        }
		],
	  "visible": "visible",
	  "active": true,
