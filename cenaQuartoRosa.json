	  "waitAudio":false,
	  "dialogue": [],
	  "conditionalDialogue": [{
          "id": "cd.QuartoRosa.01",
		  "requireStates": ["velhinhaAquecida"],
          "messages": [
          { "text": "Espero que esteja se sentindo melhor agora, senhora.", "response": "Bem melhor, garoto. Quem é você?" },
		  { "text": "Sou o Inspetor Zanko. Estou investigando o que pode ter sido um roubo.", "response": "Não sei de roubo algum. Mal saio desse quarto. Quando preciso de alguma coisa, chamo a Carolina com o meu sino." },
		  { "text": "Que sino?", "response": "Ele está nas prateleiras. Mas o que quer, afinal? \nVeio trazer o meu chá?" },
		  { "text": "Não, senhora. Viu alguém ou alguma coisa estranha hoje de tarde?", "response": "Todas as pessoas são estranhas depois de uma certa idade, garoto. Eu vi a senhorita Lúcia andando desbaratinada por aí atrás do seu chapéu." },
		  { "text": "Falou com mais alguém?", "response": "Vi a Mary circulando por aí que nem uma sirigaita. Ela disse que \n🔍 precisava de gelo para o seu drinque." },
		  { "text": "Falou com mais alguém?", "response": "Não falei, não. Estava muito frio para eu falar com quem quer que seja. E o meu chá?" },
		  { "text": "Vou pedir para a Carolina.", "response": "Quem é Carolina?" }],
		"jump": "liberouPistaMaryGelo"
		}],	  
	  "defaultDialogue": [
        { "text": "Senhora, meu nome é...", "response": "Brrrr... Me desculpe, meu querido, mas não consigo falar. \nEstá muito frio aqui!" }],
