    {
      "id": "Mary",
      "type": "Character",
      "name": "Mary",
      "img": "assets/mary.png",
	  "icon": "assets/maryPH.png",
      "width": 137,
      "height": 276,
      "x": 440,
      "y": 215,
      "color": "rgb(240, 128, 119)",
  	  "audio": "",
	  "acceptedItems": ["objTacaDrinque"],
	  "messageAccepted": 18,
	  "jumpAfterAccepted": "bloodyMaryParaMary",
      "dialogue": [ 
	    {
		"option": ["1"],
		"messages": [
          { "text": "Boa noite.", "response": "Olá, docinho. Veio trazer o meu drinque?" },
		  { "text": "Hã... não. Eu sou o Inspetor Zanko e preciso falar com a senhora.", "response": "Todos nós precisamos de coisas, querido. \nNesse momento, eu preciso do meu drinque." },
		  { "text": "Talvez eu posso ajudá-la nisso.", "response": "Eu sabia que poderia contar com você, baby." }],
		"jump": "ativarSalaEstar"
		}],
	  "jump": "",
	  "defaultDialogue": [
        { "text": "Podemos conversar?", "response": "Só com o meu drinque na mão, querido." }],
	  "specialMsg": "Cuidado. A curiosidade matou o gato.",
	  "jumpMsg": "pularGato",		 
      "conditionalDialogue": [{
          "id": "cd.SEMary.01",
		  "requireStates": ["MaryComBloodyMary"],
		  "messages": [
            { "text": "Melhor agora?", "response": "Muito melhor, docinho. O que quer de mim?" },
			{ "text": "Preciso conversar com a senhora...","response": "Senhorita, tolinho. Senhorita Mary." },
            { "text": "Certo. Senhorita, então. \nSoube do desaparecimento do 'Olho de Odin'?", "response": "É claro. De uma maneira ou de outra, tudo acaba nos meus ouvidos." },
            { "text": "Onde esteve durante a tarde?", "response": "Sou uma das suspeitas? \nQue divertido!" },
            { "text": "Estou apenas fazendo perguntas.", "response": "Cuidado. A curiosidade matou o gato." },
            { "text": "Está me ameaçando, senhorita?", "response": "Não poderia fazê-lo mal, policial.\n Não do jeito que pensa, pelo menos." },
            { "text": "Voltando ao caso, senhorita. \nOnde esteve durante a tarde?", "response": "No Quarto Azul, no segundo andar.\nDepois, perto das 17:00, vim para cá." },
            { "text": "Alguém lhe viu lá?", "response": "Isso não é uma pergunta muito decorosa, policial." },
            { "text": "Devo insistir que responda.", "response": "Infelizmente, estive sozinha por todo esse período." },
            { "text": "Viu ou ouviu algo estranho?", "response": "Só os meus pensamentos." }]
	      },
		  {
  		  "id": "cd.SEMary.02",
		  "requireStates": ["conheceuLucia"],
		  "messages": [
            { "text": "Encontrei Lúcia no Quarto Azul.", "response": "E não morreu de tédio? Está de parabéns, Inspetor." },
			{ "text": "Você a encontrou durante a tarde?","response": "Ela passou pelo quarto, procurando aquele chapéu cafona." },
            { "text": "Lúcia disse que é amiga de longa data do Dr. Meirelles.", "response": "🔍 Bem, era o mínimo que ele poderia fazer por ela, imagino." },
            { "text": "O que quer dizer com isso?", "response": "Achei que fosse um investigador. Se quer descobrir algo, investigue." }],
		  "jump": "MaryJaConheceLucia"
          },
		  {
          "id": "cd.SEMary.03",
		  "requiresClues": ["PistaMAR.GEL"],
          "messages": [
		   { "text": "A Sra. Meirelles disse que você andou circulando por aí \natrás de gelo.", "response": "Um drinque quente é que nem um beijo seco, Inspetor." },{ "text": "Você esteve na cozinha?", "response": "🔍 Acho que sim..." },{ "text": "O que tem aí nesse acho?", "response": "É uma casa grande, queridinho." }],			
           "jump": "liberarPistaMaryCozinha"}
		  ],
