	{
      "id": "General",
      "type": "Character",
      "name": "General",
      "img": "assets/generalSEM.png",
	  "icon": "assets/generalPH.png",
      "width": 95,
      "height": 282,
      "x": 630,
      "y": 210,
      "color": "rgb(138, 170, 121)",
  	  "audio": "",
	  "waitAudio": false,
      "dialogue": [ 
	    {
		"option": ["1"],
		"messages": [
          { "text": "Boa noite, general.", "response": "Olá, Inspetor. Viu alguma medalha por aí?" },
		  { "text": "Medalha?", "response": "Sim. Medalhas. Adoro medalhas. \nElas são brilhantes... douradas... requintadas." },
		  { "text": "Medalhas de combate?", "response": "O que é um combate?" },
		  { "text": "Nada, não... \nNão vi nada assim por aí. Eu queria lhe perguntar sobre...", "response": "Estou procurando medalhas, Inspetor. \nPreciso de uma. Me sinto nu sem elas." }],
		"jump": "ativarCenaSalaJogos"
		}],
	  "jump": "",
	  "acceptedItems": ["objMedalhaTampinha"],
	  "jumpAfterAccepted": "generalComMedalha",
	  "messageAccepted": 17,
	  "defaultDialogue": [
        { "text": "General, eu...", "response": "Uma medalha, Inspetor!" }],
      "conditionalDialogue": [{
          "id": "cd.SEJogos.01",
		  "requireStates": ["generalComMedalha"],
          "messages": [
            { "text": "Está satisfeito, General?", "response": "Muito. Tem visto algum comunista?" },
			{ "text": "Hã... não. E o senhor?","response": "Ah, temos prisões cheias deles." },
            { "text": "Imagino que tenham evidências sólidas contra os sujeitos.", "response": "O que são evidências?" },
            { "text": "Esquece... Onde esteve pela tarde?", "response": "Aqui, na Sala de Jogos, fumando." },
            { "text": "Cigarros?", "response": "Charutos cubanos." },
            { "text": "Hã... certo. Alguém pode confirmar isso?", "response": "Carolina esteve aqui para me trazer um drinque as 17:00." },
            { "text": "Que drinque?", "response": "Era para ser um mojito, mas ela me trouxe uísque. \nQue mulher atrapalhada!" },
            { "text": "Lembra-se de mais alguma coisa?", "response": "Não. Mas se ver algum comunista, não esqueça de me avisar. \nPreciso fechar a minha cota mensal." }	
          ],"jump":""
        },
		{
          "id": "cd.SEJogos.02",
		  "requiresClues": ["PistaLAB.GRG"],
          "messages": [
            { "text": "Olá de novo, General.", "response": "Tudo bem, rapaz? Achou algum comunista?" },
			{ "text": "Ainda não. Preciso lhe perguntar uma coisa.","response": "Pergunte, pergunte!" },
            { "text": "O que sabe sobre a nova refinaria que o Dr. Meirelles e o Dr. Marcos estão trabalhando?", "response": "Ah, isso é segredo de estado rapaz. Um segredo terrivelmente secreto. Não posso comentar." },
            { "text": "Isso seria muito importante para a investigação.", "response": "Desculpe, Inspetor. Mas é assunto de segurança nacional. Não podemos confirmar que estamos construindo uma nova refinaria em Rio Grande." },
            { "text": "Então, vocês realmente vão construir uma nova refinaria em Rio Grande?", "response": "Diabos. Não deveria ter dito isso. \nVocê não vai espalhar isso por aí, não é?" },
            { "text": "É claro que não, General.", "response": "Ótimo. Não gostaria que terminasse seus dias como os outros comunistas." },
            { "text": "Mas eu não sou comunista.", "response": "Meu caro, você é comunista se eu disser que é." }	
          ],"jump":""
        },
		{
          "id": "cd.SEJogos.03",
		  "requiresClues": ["PistaESC.TER"],
          "messages": [
            { "text": "General, encontrei uma foto sua em Rio Grande.", "response": "E?" },
			{ "text": "Elas parecem indicar que o terreno onde será construída a refinaria é seu.", "response": "Fotos comunistas, Inspetor." },
			{ "text": "Mas...","response": "Fotos comunistas. É melhor esquecer isso." }	
          ],"jump":""
        }
		],
	  "visible": "visible",
	  "active": true,
      "unlocksClues": []
    },		
