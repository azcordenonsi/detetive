	{
      "id": "Sandra",
      "type": "Character",
      "name": "Sandra",
      "img": "assets/sandra.png",
	  "icon": "assets/sandraPH.png",
      "width": 99,
      "height": 272,
      "x": 240,
      "y": 215,
      "color": "rgb(130, 237, 101)",
  	  "audio": "",
	  "waitAudio": false,
      "dialogue": [ 
	    {
		"option": ["1"],
		"messages": [
          { "text": "Boa noite, senhora. Eu sou o Inspetor Zanko.", "response": "Entende alguma coisa sobre essas coisas?" },
		  { "text": "Que coisas?", "response": "Essa vitrola de araque. \nNão consigo fazê-la funcionar." },
		  { "text": "Bem, na verdade, não. Mas eu gostaria...", "response": "Não aguento esse silêncio. Simplesmente insuportável!" }],
		"jump": "ativarCenaSalaMusica"
		}],
	  "jump": "",
	  "defaultDialogue": [
        { "text": "Podemos conversar?", "response": "A vitrola primeiro, Inspetor!" }],
	  "conditionalDialogue": [{
          "id": "cd.SLMusic.01",
		  "requireStates": ["vitrolaFuncionando"],
          "messages": [
            { "text": "Melhor agora?", "response": "Graças a Deus. Estava ficando louca com esse silêncio." },
			{ "text": "Quem é você?","response": "Sandra Boaventura. Produtora musical e ativista cultural." },
            { "text": "Trabalha com artistas?", "response": "Músicos, normalmente. Todos muito glamourosos, performáticos e brilhantes." },
            { "text": "Brilhantes como um diamante?", "response": "Dizem que os diamantes são eternos." },
            { "text": "Eterno também é o tempo de prisão para ladrões.", "response": "Acha que roubei o 'Olho de Odin', Inspetor?" },
            { "text": "Não acho nada. Minha função é ter certeza.\nOnde esteve durante toda a tarde?", "response": "Aqui, tentando fazer essa maldita vitrola funcionar." },
            { "text": "Alguém pode confirmar isso?", "response": "Lúcia e Mary estiveram por aqui por alguns momentos.\nNão vi mais ninguém." }
          ]},
		  {
           "id": "cd.SLMusic.02",
		   "requiresClues": ["PistaLAB.GRG"],
           "messages": [
		   { "text": "Você esteve no laboratório?", "response": "Quem lhe disse isso?" },{ "text": "O Dr. Marcos me contou que esteve lá fazendo revelações.", "response": "Ah, é verdade..." },{ "text": "Que tipo de fotografias?", "response": "Dos artistas que represento..." },{ "text": "Tem certeza?", "response": "🔍 Sim..." }
		   ],
		   "jump":"liberaPistaSandraFotografia"}		  
		  ],
